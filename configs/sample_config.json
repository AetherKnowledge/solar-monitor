{
  "network": {
    "mode": "ap+sta",
    "ssid": "Home Wi-Fi",
    "password": "secret123"
  },
  "mqtt": {
    "enabled": true,
    "host": "192.168.1.10",
    "port": 1883,
    "username": "user",
    "password": "pass",
    "autoDiscoveryEnabled": true,
    "autoDiscoveryPrefix": "homeassistant",
    "clientId": "solar-monitor"
  },
  "modbusDevices": [
    {
      "name": "Inverter 1",
      "identifier": "inverter_test_1",
      "slaveId": 5,
      "timeout": 2000,
      "baudrate": 2400,
      "port": 2,
      "swapBytes": true,
      "mqttEnabled": true,
      "discovery": {
        "manufacturer": "Tester",
        "model": "Tester Inverter",
        "sw_version": "1.0.0"
      },
      "readRegisters": [
        {
          "address": 4501,
          "rounding": 0,
          "transform": "Divide",
          "transformArgument": 1.0,
          "signedValue": false,
          "discovery": {
            "name": "Read Register 1",
            "unique_id": "register_1",
            "device_class": "power",
            "state_class": "measurement",
            "unit_of_measurement": "W"
          }
        },
        {
          "address": 4502,
          "rounding": 1,
          "transform": "Divide",
          "transformArgument": 10.0,
          "signedValue": false,
          "discovery": {
            "name": "Read Register 2",
            "unique_id": "register_2",
            "device_class": "voltage",
            "state_class": "measurement",
            "unit_of_measurement": "V"
          }
        }
      ],
      "virtualSensors": [
        {
          "expression": "virtual_sensor_1 + 1",
          "isPersistent": false,
          "discovery": {
            "name": "Virtual Sensor 1",
            "unique_id": "virtual_sensor_1",
            "device_class": "power",
            "state_class": "measurement",
            "unit_of_measurement": "W"
          }
        }
      ]
    }
  ]
}
