{
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm --dir web dev",
    "monitor": "pio device monitor -b 115200",
    "build:web": "pnpm --dir web build && pio run --target buildfs",
    "build:firmware": "pio run",
    "build": "pnpm build:web && pnpm build:firmware",
    "upload": "pio run -t upload",
    "upload:config": "pio run -t uploadconfig",
    "uploadfs": "pio run -t uploadfs",
    "upload:ota:firmware": "pnpm build:firmware && node scripts/ota.js firmware",
    "upload:ota:web": "pnpm build:web && node scripts/ota.js web",
    "upload:ota:config": "node scripts/ota.js config",
    "ota:restart": "node scripts/ota.js restart",
    "flash": "pnpm build:web && pnpm upload && pnpm uploadfs && pnpm monitor"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0"
  }
}
