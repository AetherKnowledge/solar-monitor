{
  "private": true,
  "scripts": {
    "dev": "pnpm --dir web dev",
    "build:web": "pnpm --dir web build",
    "build:firmware": "pio run",
    "build": "pnpm build:web && pnpm build:firmware",
    "buildfs": "pio run --target buildfs",
